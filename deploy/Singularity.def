Bootstrap: docker
From: condaforge/mambaforge:latest

%labels
    Maintainer "metaLncRNA Team <fabianomenegidio@umc.br>"
    Version "1.1.9"
    Description "Singularity container for metaLncRNA: A modular meta-predictor for lncRNA identification."

%files
    . /app

%post
    # Update system and install required build-essential libraries
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        libsvm-dev \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*

    # We need to copy environment.yml or have access to it. 
    # In Singularity, %post runs after files are copied if using %files
    
    # Update base environment using the environment.yml
    mamba env update -n base -f /app/environment.yml

    # Install metaLncRNA package from local source
    cd /app && pip install .

    # Run automated setup to bake tool environments and models into the image
    # This ensures offline usability and instant startup in HPC environments
    metalncrna setup

%environment
    export PATH=/usr/local/bin:$PATH
    export LC_ALL=C

%runscript
    # The container executes the metaLncRNA CLI by default
    exec metalncrna "$@"

%help
    This container includes metaLncRNA v1.1.9 with all required Mamba environments pre-configured.
    Usage: singularity run metaLncRNA.sif predict -i input.fasta -o output_dir/
